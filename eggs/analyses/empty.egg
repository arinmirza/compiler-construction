(rule 
  (
    (= regex (Or r1 r2))
    (empty r1)
  )
  (
    (empty regex)
  )
)

(rule 
  (
    (= regex (Or r1 r2))
    (empty r2)
  )
  (
    (empty regex)
  )
)

(rule 
  (
    (= regex (Concat r1 r2))
    (empty r1)
    (empty r2)
  )
  (
    (empty regex)
  )
)

(rule 
  (
    (= regex (Star r1))
  )
  (
    (empty regex)
  )
)

(rule 
  (
    (= regex (Opt r1))
  )
  (
    (empty regex)
  )
)

(rule 
  (
    (= regex (Epsilon))
  )
  (
    (empty regex)
  )
)